<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml

    Minimal demo layout.  Three buttons exercise the three main integration
    paths; the scrollable TextView shows live status output.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <!-- Run firmware — executes the encrypted business logic -->
    <Button
        android:id="@+id/btnRun"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_run" />

    <!-- Customer-data encryption round-trip -->
    <Button
        android:id="@+id/btnEncrypt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_encrypt" />

    <!-- SecureStore: hardware-passphrase-backed key-value store -->
    <Button
        android:id="@+id/btnStore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_store" />

    <!-- Scrollable status log -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:background="#F0F0F0"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:text="@string/status_init" />

    </ScrollView>

</LinearLayout>
